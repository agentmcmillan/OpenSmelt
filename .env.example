# OpenSmelt Configuration
# Copy to .env and fill in values:  cp .env.example .env
# Or use: ./setup.sh to generate interactively
#
# REQUIRED vars will cause docker compose to fail if missing

# === Core (REQUIRED) ===
# Generate with: openssl rand -hex 32
MEMENTO_ACCESS_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# === OpenAI (for Memento semantic search embeddings, optional) ===
OPENAI_API_KEY=

# === GitHub (REQUIRED for github-mcp backend) ===
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# === Signal Messaging (optional — requires Signal REST API) ===
# See: https://github.com/bbernhard/signal-cli-rest-api
# SIGNAL_API_URL=http://your-signal-api:8083
# SIGNAL_BOT_NUMBER=+15550001234
# SIGNAL_SENDER=+15550001234
# SIGNAL_RECIPIENT=+15550005678

# === Fleet Monitoring (optional) ===
# NAS_HOST=your-server-ip

# === Ollama (optional — for local LLM tools) ===
# Default uses host.docker.internal which works if Ollama runs on the Docker host
# OLLAMA_HOST=http://host.docker.internal:11434

# === Cloudflare (optional — enables cloudflare-mcp backend) ===
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# === External MCP (optional) ===
# CONTEXT7_URL=https://mcp.context7.com/mcp

# === Domain (for Caddy reverse proxy, optional) ===
# DOMAIN=mcp.example.com

# === Gateway ===
GATEWAY_PORT=9000
# GATEWAY_VERSION=1.2.0

# === Paths (override if non-standard) ===
# AI_SIGNALS_PATH=/path/to/ai-signals/dist
# SSH_KEYS_PATH=~/.ssh

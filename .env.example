# OpenSmelt Configuration
# Copy to .env and fill in values:  cp .env.example .env
# Or use: ./setup.sh to generate interactively
#
# REQUIRED vars will cause docker compose to fail if missing

# === Core (REQUIRED) ===
# Generate with: openssl rand -hex 32
MEMENTO_ACCESS_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# === OpenAI (for Memento semantic search embeddings, optional) ===
OPENAI_API_KEY=

# === Backends to enable (comma-separated) ===
# Core (memento, tools, rss, docker) always start. Add optional backends here:
# COMPOSE_PROFILES=github,ollama,ssh
# Available profiles: github, signal, ollama, cloudflare, ssh
COMPOSE_PROFILES=github

# === GitHub (needs profile: github) ===
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# === Signal Messaging (needs profile: signal) ===
# Requires a running Signal REST API: https://github.com/bbernhard/signal-cli-rest-api
# SIGNAL_API_URL=http://your-signal-api:8083
# SIGNAL_BOT_NUMBER=+15550001234
# SIGNAL_RECIPIENT=+15550005678

# === Fleet Monitoring (optional) ===
# NAS_HOST=your-server-ip

# === Ollama (needs profile: ollama) ===
# Default uses host.docker.internal which works on Docker Desktop (macOS/Windows).
# On Linux, use your host's LAN IP instead (e.g., http://192.168.1.100:11434).
# OLLAMA_HOST=http://host.docker.internal:11434

# === Cloudflare (needs profile: cloudflare) ===
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# === External MCP (optional) ===
# CONTEXT7_URL=https://mcp.context7.com/mcp

# === Domain (for Caddy reverse proxy, optional) ===
# DOMAIN=mcp.example.com

# === Gateway ===
GATEWAY_PORT=9000
# GATEWAY_VERSION=1.2.0

# === Paths (override if non-standard) ===
# AI_SIGNALS_PATH=/path/to/ai-signals/dist
# SSH_KEYS_PATH=./ssh-keys
